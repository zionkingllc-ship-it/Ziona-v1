{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "app/(tabs)/feed",
    "app/authGate/loading.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src/types/**/*.ts"
  ]
}
